# Personal AI OS — environment template
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# Supabase project (public — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Supabase secret key / service role — SERVER ONLY, never expose to the browser
# Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY=your_service_role_or_sb_secret_key

# Anthropic API key — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Only this email may sign in / bootstrap the owner account
OWNER_EMAIL=you@example.com

# Protects the cron-triggered daily briefing endpoint (any long random string)
CRON_SECRET=change-me-to-a-long-random-string

# Models (optional overrides)
CEO_MODEL=claude-sonnet-5
SPECIALIST_MODEL=claude-haiku-4-5-20251001

# Google connector (optional — Calendar read + Gmail read/draft).
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web application).
# Authorized redirect URI: https://YOUR_DOMAIN/api/connectors/google/callback
# (and http://localhost:3000/api/connectors/google/callback for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
